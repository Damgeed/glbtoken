# Required
NEW_API_BASE_URL=https://glbtoken-new-api.up.railway.app
NEW_API_ADMIN_TOKEN=set-this-after-deploying-new-api
DATABASE_URL=postgresql://user:pass@host:5432/glbtoken

# Auth
JWT_SECRET=change-this-to-a-random-secret

# OAuth / Social Login (optional)
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# SMTP (for password reset, email verification)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@glbtoken.io

# Payment (optional - set at least one)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CRYPTO_USDT_TRC20=
CRYPTO_USDT_ERC20=
CRYPTO_BTC=
CRYPTO_ETH=

# Fallback (only used if New API is not available)
FALLBACK_API_KEY=
FALLBACK_API_URL=

# Server
PORT=8000
