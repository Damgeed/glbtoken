# GlbTOKEN Backend — Environment Variables
# Copy this to .env and fill in values:
#   cp .env.example .env

# JWT signing secret (required — generate with: openssl rand -hex 32)
# If not set, a random one is generated on each restart (sessions will be invalidated)
GLBTOKEN_SECRET=

# Google OAuth (optional — for "Sign in with Google")
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (optional — for "Sign in with GitHub")
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# SMTP for email verification & password reset (optional — prints to console if unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@glbtoken.io

# Paystack (optional — African payments)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# Stripe (optional — global card payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Crypto wallet addresses (optional — placeholder addresses)
CRYPTO_USDT_TRC20=
CRYPTO_USDT_ERC20=
CRYPTO_BTC=
CRYPTO_ETH=

# OpenRouter API Key (required for API proxy — chat completions)
OPENROUTER_API_KEY=

# Server port (default: 8000)
PORT=8000

# Uvicorn worker count (default: 4, Railway auto-sets this)
UVICORN_WORKERS=4
